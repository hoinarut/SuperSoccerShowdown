project_name = "sss"
environment  = "dev"
aws_region   = "eu-west-1"

# Required when enable_rds = false
database_connection_string = "Server=your-sql-server;Database=sss;User ID=sa;Password=change-me;TrustServerCertificate=true;"

# Set by CI when deploying the API package.
# lambda_deployment_package_path = "../artifacts/api.zip"
# lambda_package_version         = "local-build"

lambda_memory_mb       = 1024
lambda_timeout_seconds = 30
lambda_runtime         = "dotnet10"
lambda_handler         = "MyApp.Api"

# Optional managed SQL Server (adds VPC + NAT + RDS cost)
enable_rds  = false
db_username = "sssadmin"
# db_password = "change-me"
